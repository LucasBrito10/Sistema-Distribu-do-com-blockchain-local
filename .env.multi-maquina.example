# Copie este arquivo para .env em CADA máquina e ajuste os valores.
# O CLUSTER_IPS deve ser igual em todas as máquinas.
# O SETOR_NOME e o PUBLIC_ADDRESS devem ser específicos da máquina atual.

SETOR_NOME=SETOR_NORTE
CLUSTER_IPS=192.168.1.10,192.168.1.11,192.168.1.12,192.168.1.13
PUBLIC_ADDRESS=192.168.1.10

